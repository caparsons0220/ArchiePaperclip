# Copy these values into Hostinger Docker Manager or use:
# docker compose --env-file docker/.env.hostinger.example -f docker/docker-compose.hostinger.yml config
#
# Keep ARCHIE_DB_PASSWORD URL-safe because it is interpolated into DATABASE_URL.

PAPERCLIP_PUBLIC_URL=https://app.archiebravo.com
ARCHIE_HOSTNAME=app.archiebravo.com
TRAEFIK_CERT_RESOLVER=letsencrypt
PAPERCLIP_DEPLOYMENT_MODE=authenticated
PAPERCLIP_DEPLOYMENT_EXPOSURE=public
BETTER_AUTH_SECRET=replace-with-a-long-random-secret

ARCHIE_DB_NAME=paperclip
ARCHIE_DB_USER=paperclip
ARCHIE_DB_PASSWORD=replace-with-a-url-safe-password

PAPERCLIP_AUTH_DISABLE_SIGN_UP=false

# Leave blank unless you need hostnames beyond the PAPERCLIP_PUBLIC_URL host.
PAPERCLIP_ALLOWED_HOSTNAMES=

# Optional provider keys for local adapters.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
